<%- include('../partials/head', { title: 'เข้าสู่ระบบ' }) %>

<div class="auth-page">
  <div class="auth-card">
    <div class="auth-logo">
      <img src="<%= shopLogo %>" alt="Logo" style="width:80px;height:80px;object-fit:cover;border-radius:16px;margin-bottom:12px;box-shadow:0 4px 16px rgba(0,0,0,0.12);">
      <h1>Lunarlyn IT</h1>
      <p>ร้านอุปกรณ์ IT ที่คุณไว้ใจได้</p>
    </div>

    <% if (error) { %>
      <div class="alert alert-error">⚠️ <%= error %></div>
    <% } %>
    <% if (success) { %>
      <div class="alert alert-success">✅ <%= success %></div>
    <% } %>

    <form method="POST" action="/login">
      <div class="form-group">
        <label class="form-label">ชื่อผู้ใช้</label>
        <input type="text" name="username" class="form-control" placeholder="กรอกชื่อผู้ใช้" required autofocus>
      </div>
      <div class="form-group">
        <label class="form-label">รหัสผ่าน</label>
        <input type="password" name="password" class="form-control" placeholder="กรอกรหัสผ่าน" required>
      </div>
      <button type="submit" class="btn btn-primary w-100 btn-lg" style="justify-content:center; margin-top:8px;">
        🔐 เข้าสู่ระบบ
      </button>
    </form>

    <div class="divider"></div>

    <div class="text-center" style="font-size: 13px; color: var(--text-light);">
      ยังไม่มีบัญชี?
      <a href="/register" style="color: #c060a0; font-weight: 600;">สมัครสมาชิก</a>
    </div>
  </div>
</div>

<%- include('../partials/foot') %>
