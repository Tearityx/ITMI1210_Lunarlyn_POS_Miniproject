<%- include('../partials/head', { title: 'จัดการสินค้า' }) %>
<%- include('../partials/sidebar', { currentPage: 'products' }) %>

<div class="main-content">
  <div class="page-header">
    <div class="page-title">📦 จัดการสินค้า</div>
    <a href="/products/add" class="btn btn-primary">+ เพิ่มสินค้า</a>
  </div>

  <% if (success) { %>
    <div class="alert alert-success">✅ <%= success %></div>
  <% } %>
  <% if (error) { %>
    <div class="alert alert-error">⚠️ <%= error %></div>
  <% } %>

  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>รูป</th>
          <th>ชื่อสินค้า</th>
          <th>หมวดหมู่</th>
          <th>ราคา</th>
          <th>สต็อก</th>
          <th>สถานะ</th>
          <th>จัดการ</th>
        </tr>
      </thead>
      <tbody>
        <% if (products.length === 0) { %>
          <tr><td colspan="7" class="no-records">ยังไม่มีสินค้า</td></tr>
        <% } %>
        <% products.forEach(p => { %>
          <tr>
            <td>
              <% if (p.image) { %>
                <img src="<%= p.image %>" style="width:48px;height:48px;border-radius:8px;object-fit:cover;">
              <% } else { %>
                <div style="width:48px;height:48px;border-radius:8px;background:var(--pink-light);display:flex;align-items:center;justify-content:center;font-size:22px;">📦</div>
              <% } %>
            </td>
            <td>
              <strong><%= p.name %></strong>
              <div style="font-size:11px;color:var(--text-light)"><%= p.description.substring(0,50) %></div>
            </td>
            <td><span class="badge badge-blue"><%= p.category %></span></td>
            <td class="price fw-700">฿<%= p.price.toLocaleString() %></td>
            <td>
              <span class="<%= p.stock <= 5 ? 'badge badge-pink' : 'badge badge-green' %>">
                <%= p.stock %> ชิ้น
              </span>
            </td>
            <td>
              <span class="<%= p.isActive ? 'badge badge-green' : 'badge badge-gray' %>">
                <%= p.isActive ? 'ขายอยู่' : 'หยุดขาย' %>
              </span>
            </td>
            <td>
              <div class="d-flex gap-2">
                <a href="/products/edit/<%= p._id %>" class="btn btn-outline btn-sm">✏️ แก้ไข</a>
                <form method="POST" action="/products/delete/<%= p._id %>" onsubmit="return confirm('ลบสินค้านี้?')">
                  <button type="submit" class="btn btn-danger btn-sm">🗑️ ลบ</button>
                </form>
              </div>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<%- include('../partials/foot') %>
