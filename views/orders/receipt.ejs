<%- include('../partials/head', { title: 'ใบเสร็จ ' + order.orderNumber }) %>
<%- include('../partials/sidebar', { currentPage: user && user.role === 'customer' ? 'myorders' : 'orders' }) %>

<div class="main-content">
  <div class="page-header">
    <div class="page-title">🧾 <%= order.status === 'pending' ? 'ยืนยันคำสั่งซื้อ' : 'ใบเสร็จรับเงิน' %></div>
    <div class="d-flex gap-2">
      <% if (order.status === 'completed') { %>
        <button onclick="window.print()" class="btn btn-outline">🖨️ พิมพ์</button>
      <% } %>
      <a href="/orders" class="btn btn-outline">← กลับ</a>
    </div>
  </div>

  <div class="receipt">
    <div class="receipt-header">
      <% if (shopLogo) { %>
        <img src="<%= shopLogo %>" alt="Logo" style="height:56px;border-radius:10px;margin-bottom:8px;">
      <% } else { %>
        <div style="font-size: 28px; margin-bottom: 4px;">💻</div>
      <% } %>
      <h2 style="font-size: 20px; font-weight: 700; color: var(--text);">Lunarlyn IT</h2>
      <p style="font-size: 12px; color: var(--text); margin-top: 2px;">ร้านอุปกรณ์ IT ครบวงจร</p>
    </div>

    <!-- สถานะออเดอร์ -->
    <div style="text-align:center;padding:10px 0;margin-bottom:8px;">
      <% if (order.status === 'pending') { %>
        <span class="badge badge-pink" style="font-size:14px;padding:6px 16px;">⏳ รอพนักงานรับออเดอร์</span>
      <% } else if (order.status === 'accepted') { %>
        <span class="badge badge-blue" style="font-size:14px;padding:6px 16px;">🔄 กำลังดำเนินการ</span>
      <% } else if (order.status === 'completed') { %>
        <span class="badge badge-green" style="font-size:14px;padding:6px 16px;">✅ เสร็จสิ้น</span>
      <% } else { %>
        <span class="badge badge-gray" style="font-size:14px;padding:6px 16px;">❌ ยกเลิกแล้ว</span>
      <% } %>
    </div>

    <div class="receipt-body">
      <div class="grid-2 mb-4">
        <div>
          <div style="font-size: 11px; color: var(--text-light); margin-bottom: 2px;">เลขที่ออเดอร์</div>
          <div style="font-size: 18px; font-weight: 700; color: #c060a0;"><%= order.orderNumber %></div>
        </div>
        <div class="text-right">
          <div style="font-size: 11px; color: var(--text-light); margin-bottom: 2px;">วันที่</div>
          <div style="font-size: 13px; font-weight: 600;">
            <%= order.createdAt.toLocaleDateString('th-TH', { year: 'numeric', month: 'long', day: 'numeric' }) %>
          </div>
          <div style="font-size: 12px; color: var(--text-light);">
            <%= order.createdAt.toLocaleTimeString('th-TH', { hour: '2-digit', minute: '2-digit' }) %> น.
          </div>
        </div>
      </div>

      <div class="divider"></div>

      <div style="margin-bottom: 16px;">
        <div style="font-size: 11px; color: var(--text-light); margin-bottom: 4px;">ลูกค้า</div>
        <div style="font-weight: 600;"><%= order.customerName %></div>
        <div style="font-size: 12px; color: var(--text-light);">ช่องทางชำระ: <%= order.paymentMethod %></div>
        <% if (order.employeeName) { %>
          <div style="font-size: 12px; color: var(--text-light);">พนักงาน: <%= order.employeeName %></div>
        <% } %>
        <% if (order.note) { %>
          <div style="font-size: 12px; color: var(--text-light);">หมายเหตุ: <%= order.note %></div>
        <% } %>
      </div>

      <div class="divider"></div>

      <div style="margin-bottom: 16px;">
        <div style="font-size: 12px; font-weight: 600; color: var(--text-light); margin-bottom: 10px; text-transform: uppercase; letter-spacing: 0.5px;">รายการสินค้า</div>
        <% order.items.forEach(item => { %>
          <div style="display:flex; justify-content:space-between; align-items:center; padding: 8px 0; border-bottom: 1px solid var(--border);">
            <div>
              <div style="font-size: 14px; font-weight: 500;"><%= item.productName %></div>
              <div style="font-size: 12px; color: var(--text-light);">฿<%= item.price.toLocaleString() %> × <%= item.quantity %> ชิ้น</div>
            </div>
            <div class="price fw-700">฿<%= item.subtotal.toLocaleString() %></div>
          </div>
        <% }) %>
      </div>

      <div style="background: linear-gradient(135deg, var(--pink-light), var(--blue-light)); border-radius: 10px; padding: 16px;">
        <div style="display:flex; justify-content:space-between; align-items:center;">
          <div style="font-size: 16px; font-weight: 700; color: var(--text);">ยอดรวมทั้งหมด</div>
          <div style="font-size: 24px; font-weight: 700; color: #c060a0;">฿<%= order.totalAmount.toLocaleString() %></div>
        </div>
      </div>
    </div>

    <div class="receipt-footer">
      <% if (order.status === 'pending') { %>
        ⏳ ขอบคุณที่สั่งซื้อ! พนักงานจะรับออเดอร์ของคุณเร็วๆ นี้ 💖
      <% } else { %>
        ขอบคุณที่ใช้บริการ Lunarlyn IT 💖<br>
        คุณภาพดี ราคายุติธรรม บริการใจดี
      <% } %>
    </div>
  </div>

  <div class="text-center mt-4">
    <% if (user && user.role === 'customer') { %>
      <a href="/shop" class="btn btn-primary">🛍️ สั่งซื้อต่อ</a>
      <a href="/orders" class="btn btn-outline" style="margin-left: 8px;">ดูคำสั่งซื้อทั้งหมด</a>
    <% } else { %>
      <a href="/orders" class="btn btn-outline">← กลับหน้าออเดอร์</a>
      <a href="/pos" class="btn btn-primary" style="margin-left:8px;">🖥️ ไปที่ POS</a>
    <% } %>
  </div>
</div>

<style>
@media print {
  .sidebar, .page-header, .main-content > div:last-child { display: none; }
  .main-content { margin: 0; padding: 0; }
  .receipt { box-shadow: none; border: 1px solid #ccc; }
}
</style>

<%- include('../partials/foot') %>
