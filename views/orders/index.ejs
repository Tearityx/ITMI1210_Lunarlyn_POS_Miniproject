<%- include('../partials/head', { title: 'ออเดอร์' }) %>
<%- include('../partials/sidebar', { currentPage: user && user.role === 'customer' ? 'myorders' : 'orders' }) %>

<div class="main-content">
  <div class="page-header">
    <div class="page-title">
      🧾 <%= user && user.role === 'customer' ? 'ประวัติการสั่งซื้อ' : 'รายการออเดอร์' %>
    </div>
    <% if (user && user.role !== 'customer') { %>
      <div style="font-size:13px;color:var(--text-light);">
        <span class="badge badge-pink" style="margin-right:4px;">● รอรับ</span>
        <span class="badge badge-blue" style="margin-right:4px;">● รับแล้ว</span>
        <span class="badge badge-green">● เสร็จแล้ว</span>
      </div>
    <% } %>
  </div>

  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>เลขออเดอร์</th>
          <th>ลูกค้า</th>
          <th>วันที่</th>
          <th>ช่องทางชำระ</th>
          <th>จำนวนสินค้า</th>
          <th class="text-right">ยอดรวม</th>
          <th>สถานะ</th>
          <% if (user && user.role !== 'customer') { %><th>จัดการ</th><% } %>
        </tr>
      </thead>
      <tbody>
        <% if (orders.length === 0) { %>
          <tr><td colspan="8" class="no-records">ยังไม่มีออเดอร์</td></tr>
        <% } %>
        <% orders.forEach(order => { %>
          <tr>
            <td><strong><%= order.orderNumber %></strong></td>
            <td><%= order.customerName %></td>
            <td style="font-size:12px;color:var(--text-light);">
              <%= order.createdAt.toLocaleDateString('th-TH', { year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %>
            </td>
            <td><span class="badge badge-blue"><%= order.paymentMethod %></span></td>
            <td><%= order.items.length %> รายการ</td>
            <td class="text-right price fw-700">฿<%= order.totalAmount.toLocaleString() %></td>
            <td>
              <% if (order.status === 'pending') { %>
                <span class="badge badge-pink">⏳ รอรับออเดอร์</span>
              <% } else if (order.status === 'accepted') { %>
                <span class="badge badge-blue">🔄 กำลังดำเนินการ</span>
                <% if (order.employeeName) { %>
                  <div style="font-size:11px;color:var(--text-light);margin-top:2px;">โดย: <%= order.employeeName %></div>
                <% } %>
              <% } else if (order.status === 'completed') { %>
                <span class="badge badge-green">✅ เสร็จสิ้น</span>
              <% } else { %>
                <span class="badge badge-gray">❌ ยกเลิก</span>
              <% } %>
            </td>
            <% if (user && user.role !== 'customer') { %>
              <td>
                <div class="d-flex gap-2" style="flex-wrap:wrap;">
                  <a href="/orders/receipt/<%= order._id %>" class="btn btn-outline btn-sm">🧾 ดู</a>
                  <% if (order.status === 'pending') { %>
                    <form method="POST" action="/orders/accept/<%= order._id %>">
                      <button type="submit" class="btn btn-primary btn-sm">✋ รับออเดอร์</button>
                    </form>
                  <% } %>
                  <% if (order.status === 'accepted') { %>
                    <% const isMyOrder = order.employee && order.employee.toString() === user._id.toString() %>
                    <% if (user.role === 'manager' || isMyOrder) { %>
                      <form method="POST" action="/orders/complete/<%= order._id %>">
                        <button type="submit" class="btn btn-secondary btn-sm">✅ เสร็จสิ้น</button>
                      </form>
                    <% } %>
                  <% } %>
                  <% if (order.status !== 'completed' && order.status !== 'cancelled') { %>
                    <% if (user.role === 'manager') { %>
                      <form method="POST" action="/orders/cancel/<%= order._id %>" onsubmit="return confirm('ยกเลิกออเดอร์นี้?')">
                        <button type="submit" class="btn btn-danger btn-sm">❌ ยกเลิก</button>
                      </form>
                    <% } %>
                  <% } %>
                </div>
              </td>
            <% } %>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<%- include('../partials/foot') %>
