<%- include('../partials/head', { title: 'จัดการลูกค้า' }) %>
<%- include('../partials/sidebar', { currentPage: 'customers' }) %>

<div class="main-content">
  <div class="page-header">
    <div class="page-title">🧑‍🤝‍🧑 จัดการลูกค้า</div>
    <span class="badge badge-blue"><%= customers.length %> ลูกค้า</span>
  </div>

  <% if (success) { %>
    <div class="alert alert-success">✅ <%= success %></div>
  <% } %>

  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>ลูกค้า</th>
          <th>ชื่อผู้ใช้</th>
          <th>อีเมล</th>
          <th>เบอร์โทร</th>
          <th>ที่อยู่</th>
          <th>วันที่สมัคร</th>
        </tr>
      </thead>
      <tbody>
        <% if (customers.length === 0) { %>
          <tr><td colspan="6" class="no-records">ยังไม่มีลูกค้า</td></tr>
        <% } %>
        <% customers.forEach(c => { %>
          <tr>
            <td>
              <div class="d-flex align-center gap-2">
                <% if (c.profileImage) { %>
                  <img src="<%= c.profileImage %>" class="avatar" style="width:36px;height:36px;">
                <% } else { %>
                  <div class="avatar-placeholder" style="width:36px;height:36px;font-size:13px;background:linear-gradient(135deg,var(--purple),var(--blue-dark));">
                    <%= c.displayName ? c.displayName.charAt(0).toUpperCase() : c.username.charAt(0).toUpperCase() %>
                  </div>
                <% } %>
                <strong><%= c.displayName || c.username %></strong>
              </div>
            </td>
            <td style="color:var(--text-light);font-size:13px;">@<%= c.username %></td>
            <td style="font-size:13px;"><%= c.email || '-' %></td>
            <td style="font-size:13px;"><%= c.phone || '-' %></td>
            <td style="font-size:13px;max-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= c.address || '-' %></td>
            <td style="font-size:12px;color:var(--text-light);"><%= c.createdAt.toLocaleDateString('th-TH') %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<%- include('../partials/foot') %>
